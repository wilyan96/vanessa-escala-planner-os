generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  COORDINATOR
  ASSISTANT
  FINANCE
  CLIENT
  VENDOR
}

enum ClientStatus {
  PROSPECT
  QUOTED
  CONTRACTED
  PLANNING
  EVENT_COMPLETED
  CLOSED
}

enum EventType {
  WEDDING
  QUINCEANERA
  CORPORATE
  BIRTHDAY
  RELIGIOUS
  SOCIAL
}

enum EventStatus {
  DRAFT
  ACTIVE
  PLANNING
  EXECUTION_READY
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  PENDING
  CONFIRMED
  DONE
  OVERDUE
}

enum VendorStatus {
  ACTIVE
  RECOMMENDED
  PENDING
  NOT_RECOMMENDED
}

enum DocumentKind {
  QUOTE
  CONTRACT
  PAYMENT_RECEIPT
  INSPIRATION
  GUEST_LIST
  TIMELINE
  MENU
  VENDOR_PROPOSAL
  CEREMONY_PROGRAM
  OTHER
}

enum AlertCategory {
  COMMERCIAL
  FINANCIAL
  OPERATIONAL
  LEGAL
  CALENDAR
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum CalendarEventKind {
  EVENT
  MEETING
  REHEARSAL
  SETUP
  TEARDOWN
  PAYMENT
  FOLLOW_UP
  VENDOR_ARRIVAL
}

enum ReportKind {
  GENERAL_MONTHLY
  FINANCIAL_MONTHLY
  EVENT
  INCOME_EXPENSE
  PENDING_PAYMENTS
  PROVIDERS
  QUOTES
  CONTRACTS
  OVERDUE_TASKS
  EVENT_FINAL
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  brandName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  clients        Client[]
  events         Event[]
  vendors        Vendor[]
  templates      Template[]
  alerts         Alert[]
  emails         Email[]
  receipts       Receipt[]
  calendarEvents CalendarEvent[]
  activityLogs   ActivityLog[]
  reports        Report[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  name           String
  role           UserRole
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id])
  assignments    TeamMember[]
  tasks          Task[]        @relation("TaskAssignee")
  assignedAlerts Alert[]       @relation("AlertAssignee")
  activityLogs   ActivityLog[]
}

model Client {
  id              String       @id @default(cuid())
  organizationId  String
  fullName        String
  phone           String?
  email           String?
  eventType       EventType
  eventDate       DateTime?
  eventPlace      String?
  guestCount      Int?
  estimatedBudget Decimal?
  status          ClientStatus @default(PROSPECT)
  leadSource      String?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  internalNotes   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  events         Event[]
  interactions   Interaction[]
  documents      Document[]
  quotes         Quote[]
  contracts      Contract[]
  payments       Payment[]
  alerts         Alert[]
  emails         Email[]
  calendarEvents CalendarEvent[]
  activityLogs   ActivityLog[]
  reports        Report[]
}

model Event {
  id                    String      @id @default(cuid())
  organizationId        String
  clientId              String
  name                  String
  type                  EventType
  date                  DateTime
  startTime             DateTime?
  endTime               DateTime?
  ceremonyPlace         String?
  receptionPlace        String?
  guestCount            Int?
  budget                Decimal?
  status                EventStatus @default(PLANNING)
  commercialStatus      String?
  financialStatus       String      @default("Sin abono")
  operationalStatus     String      @default("Pendiente")
  progress              Int         @default(0)
  isTimelineComplete    Boolean     @default(false)
  isChecklistComplete   Boolean     @default(false)
  googleCalendarEventId String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  client           Client            @relation(fields: [clientId], references: [id])
  services         EventService[]
  quotes           Quote[]
  contracts        Contract[]
  timeline         TimelineItem[]
  tasks            Task[]
  vendors          EventVendor[]
  team             TeamMember[]
  guests           Guest[]
  tables           SeatingTable[]
  documents        Document[]
  payments         Payment[]
  expenses         Expense[]
  providerPayments ProviderPayment[]
  alerts           Alert[]
  emails           Email[]
  calendarEvents   CalendarEvent[]
  activityLogs     ActivityLog[]
  reports          Report[]
}

model EventService {
  id             String   @id @default(cuid())
  eventId        String
  name           String
  category       String
  description    String?
  quantity       Int      @default(1)
  unitPrice      Decimal  @default(0)
  status         String   @default("pending")
  vendorRequired Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])
}

model TimelineItem {
  id        String     @id @default(cuid())
  eventId   String
  time      DateTime
  activity  String
  owner     String?
  place     String?
  vendorId  String?
  notes     String?
  status    TaskStatus @default(PENDING)
  sortOrder Int        @default(0)

  event  Event   @relation(fields: [eventId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  eventId     String?
  assigneeId  String?
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(PENDING)
  isInternal  Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  event    Event?  @relation(fields: [eventId], references: [id])
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  alerts   Alert[]
}

model Vendor {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  category       String
  contactName    String?
  phone          String?
  email          String?
  socialLinks    Json?
  referenceRates Decimal?
  notes          String?
  status         VendorStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  events           EventVendor[]
  timeline         TimelineItem[]
  documents        Document[]
  expenses         Expense[]
  providerPayments ProviderPayment[]
  alerts           Alert[]
}

model EventVendor {
  id               String    @id @default(cuid())
  eventId          String
  vendorId         String
  service          String
  status           String    @default("pending")
  contractedAmount Decimal?
  paidAmount       Decimal   @default(0)
  contractStatus   String    @default("pending")
  paymentStatus    String    @default("pending")
  arrivalAt        DateTime?
  confirmedAt      DateTime?
  rating           Int?
  notes            String?

  event  Event  @relation(fields: [eventId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([eventId, vendorId, service])
}

model Quote {
  id          String   @id @default(cuid())
  clientId    String
  eventId     String?
  quoteNumber String   @unique
  expiresAt   DateTime
  subtotal    Decimal
  discount    Decimal  @default(0)
  tax         Decimal  @default(0)
  total       Decimal
  status      String   @default("draft")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client      @relation(fields: [clientId], references: [id])
  event     Event?      @relation(fields: [eventId], references: [id])
  items     QuoteItem[]
  contracts Contract[]
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  serviceName String
  description String?
  unitPrice   Decimal
  quantity    Int     @default(1)
  subtotal    Decimal

  quote Quote @relation(fields: [quoteId], references: [id])
}

model Contract {
  id                String    @id @default(cuid())
  clientId          String
  eventId           String?
  quoteId           String?
  templateId        String?
  title             String
  content           String
  status            String    @default("draft")
  sentAt            DateTime?
  signatureDeadline DateTime?
  signedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client    Client     @relation(fields: [clientId], references: [id])
  event     Event?     @relation(fields: [eventId], references: [id])
  quote     Quote?     @relation(fields: [quoteId], references: [id])
  documents Document[]
  alerts    Alert[]
}

model Payment {
  id          String    @id @default(cuid())
  clientId    String
  eventId     String?
  amount      Decimal
  dueDate     DateTime?
  paidAt      DateTime?
  method      String?
  receiptUrl  String?
  status      String    @default("pending")
  description String?
  createdAt   DateTime  @default(now())

  client Client  @relation(fields: [clientId], references: [id])
  event  Event?  @relation(fields: [eventId], references: [id])
  alerts Alert[]
}

model Receipt {
  id             String   @id @default(cuid())
  organizationId String
  eventId        String?
  receiptNumber  String   @unique
  client         String
  clientEmail    String?
  clientPhone    String?
  eventName      String?
  eventDate      String?
  eventPlace     String?
  accountNumber  String?
  issueDate      String?
  paymentDueDate String?
  paymentMethod  String?
  serviceCharge  Decimal  @default(0)
  itbmsRate      Decimal  @default(0)
  deliveryFee    Decimal  @default(0)
  notes          String?
  status         String   @default("Borrador")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  items        ReceiptItem[]

  @@index([organizationId, receiptNumber])
  @@index([eventId])
}

model ReceiptItem {
  id          String  @id @default(cuid())
  receiptId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0)

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String    @id @default(cuid())
  eventId     String
  vendorId    String?
  amount      Decimal
  category    String
  description String?
  dueDate     DateTime?
  paidAt      DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())

  event  Event   @relation(fields: [eventId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])
}

model ProviderPayment {
  id         String    @id @default(cuid())
  eventId    String
  vendorId   String
  amount     Decimal
  paidAmount Decimal   @default(0)
  dueDate    DateTime?
  paidAt     DateTime?
  method     String?
  receiptUrl String?
  status     String    @default("pending")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  event  Event  @relation(fields: [eventId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])
}

model Document {
  id         String       @id @default(cuid())
  clientId   String?
  eventId    String?
  vendorId   String?
  kind       DocumentKind
  name       String
  url        String
  mimeType   String
  sizeBytes  Int?
  isInternal Boolean      @default(true)
  contractId String?
  createdAt  DateTime     @default(now())

  client   Client?   @relation(fields: [clientId], references: [id])
  event    Event?    @relation(fields: [eventId], references: [id])
  vendor   Vendor?   @relation(fields: [vendorId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])
}

model Guest {
  id             String  @id @default(cuid())
  eventId        String
  fullName       String
  rsvpStatus     String  @default("pending")
  companions     Int     @default(0)
  specialMenu    String?
  notes          String?
  seatingTableId String?

  event        Event         @relation(fields: [eventId], references: [id])
  seatingTable SeatingTable? @relation(fields: [seatingTableId], references: [id])
}

model SeatingTable {
  id       String @id @default(cuid())
  eventId  String
  name     String
  capacity Int
  kind     String @default("general")

  event  Event   @relation(fields: [eventId], references: [id])
  guests Guest[]
}

model TeamMember {
  id            String    @id @default(cuid())
  eventId       String
  userId        String
  role          String
  startsAt      DateTime?
  endsAt        DateTime?
  agreedPay     Decimal?
  paymentStatus String    @default("pending")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model Interaction {
  id       String   @id @default(cuid())
  clientId String
  channel  String
  subject  String?
  body     String
  sentAt   DateTime @default(now())
  metadata Json?

  client Client @relation(fields: [clientId], references: [id])
}

model Template {
  id             String   @id @default(cuid())
  organizationId String
  type           String
  name           String
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model Alert {
  id                String        @id @default(cuid())
  organizationId    String
  clientId          String?
  eventId           String?
  contractId        String?
  paymentId         String?
  vendorId          String?
  taskId            String?
  assigneeId        String?
  title             String
  category          AlertCategory
  priority          AlertPriority
  dueDate           DateTime?
  status            AlertStatus   @default(OPEN)
  recommendedAction String
  resolvedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])
  task         Task?        @relation(fields: [taskId], references: [id])
  assignee     User?        @relation("AlertAssignee", fields: [assigneeId], references: [id])

  @@index([organizationId, status, priority])
  @@index([eventId])
  @@index([clientId])
}

model Email {
  id             String    @id @default(cuid())
  organizationId String
  clientId       String?
  eventId        String?
  templateId     String?
  to             String
  subject        String
  body           String
  status         String    @default("draft")
  provider       String?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])
}

model CalendarEvent {
  id                    String            @id @default(cuid())
  organizationId        String
  clientId              String?
  eventId               String?
  kind                  CalendarEventKind
  title                 String
  startsAt              DateTime
  endsAt                DateTime?
  location              String?
  googleCalendarEventId String?
  status                String            @default("scheduled")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])

  @@index([organizationId, startsAt])
  @@index([eventId])
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  clientId       String?
  eventId        String?
  action         String
  summary        String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])

  @@index([organizationId, createdAt])
  @@index([eventId])
}

model Report {
  id             String     @id @default(cuid())
  organizationId String
  clientId       String?
  eventId        String?
  kind           ReportKind
  title          String
  periodStart    DateTime?
  periodEnd      DateTime?
  payload        Json
  pdfUrl         String?
  generatedAt    DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])

  @@index([organizationId, kind, generatedAt])
  @@index([eventId])
}
